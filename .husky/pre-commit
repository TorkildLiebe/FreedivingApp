echo "Running pre-commit checks..."

# Prevent direct commits to main branch
branch=$(git symbolic-ref HEAD | sed -e 's,.*/\(.*\),\1,')
if [ "$branch" = "main" ]; then
  echo "Direct commits to main branch are not allowed!"
  echo ""
  echo "Please create a feature branch:"
  echo "  git checkout -b feature/your-feature-name"
  echo ""
  echo "Or switch to an existing branch:"
  echo "  git checkout your-branch-name"
  echo ""
  exit 1
fi

# Warn if current branch has already been merged to main
CURRENT_BRANCH=$(git branch --show-current)
if git fetch origin main --quiet 2>/dev/null && git branch -r --merged origin/main 2>/dev/null | grep -q "origin/$CURRENT_BRANCH"; then
  echo ""
  echo "⚠️  WARNING: Branch '$CURRENT_BRANCH' appears to already be merged into main!"
  echo ""
  echo "You probably want to create a new branch:"
  echo "  git checkout main && git pull && git checkout -b feat/new-feature"
  echo ""
  echo "To proceed anyway: git commit --no-verify"
  exit 1
fi

# Run linting for backend and mobile
echo "Linting backend..."
pnpm --filter backend lint || exit 1

echo "Linting mobile..."
pnpm --filter mobile lint || exit 1

# Run type checking
echo "Type checking backend..."
pnpm --filter backend type-check || exit 1

echo "Type checking mobile..."
pnpm --filter mobile type-check || exit 1

echo "Pre-commit checks passed!"
