{
  "name": "freediving-app",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter backend run start:dev",
    "dev:mobile": "pnpm --filter mobile exec expo run:ios",
    "dev:infra": "supabase start",
    "dev:infra:down": "supabase stop",
    "codex:hook:pre-edit": ".codex/hooks/run-hook.sh pre-edit",
    "codex:hook:post-edit": ".codex/hooks/run-hook.sh post-edit",
    "codex:hook:pre-commit": ".codex/hooks/run-hook.sh pre-commit",
    "codex:hook:post-test": ".codex/hooks/run-hook.sh post-test",
    "codex:hook:all": ".codex/hooks/run-hook.sh",
    "test:backend": "pnpm --filter backend run test",
    "test:backend:e2e": "pnpm --filter backend run test:e2e",
    "test:mobile": "pnpm --filter mobile test",
    "test:mobile:watch": "pnpm --filter mobile test:watch",
    "test:mobile:coverage": "pnpm --filter mobile test:coverage",
    "test:all": "pnpm test:backend && pnpm test:mobile",
    "lint:backend": "pnpm --filter backend run lint",
    "lint:mobile": "pnpm --filter mobile run lint",
    "lint": "pnpm lint:backend && pnpm lint:mobile",
    "lint:fix": "pnpm --filter backend run lint:fix && pnpm --filter mobile run lint:fix",
    "prisma:generate": "pnpm --filter backend exec prisma generate",
    "prisma:migrate": "pnpm --filter backend exec prisma migrate dev",
    "prisma:studio": "pnpm --filter backend exec prisma studio",
    "prisma:validate": "pnpm --filter backend exec prisma validate",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
