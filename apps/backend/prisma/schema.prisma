generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pg_graphql, pg_net, pg_stat_statements, pgcrypto, supabase_vault, uuid_ossp(map: "uuid-ossp")]
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("health_checks")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  externalId        String    @unique @map("external_id")
  email             String?
  alias             String?   @db.VarChar(120) @map("alias")
  bio               String?   @db.VarChar(300) @map("bio")
  avatarUrl         String?   @map("avatar_url")
  role              String    @default("user")
  preferredLanguage String    @default("no") @map("preferred_language")
  favoriteSpotIds   String[]  @default([]) @map("favorite_spot_ids") @db.Uuid
  isDeleted         Boolean   @default(false) @map("is_deleted")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  spots        DiveSpot[]
  diveLogs     DiveLog[]
  spotRatings  SpotRating[]

  @@map("users")
}

model DiveSpot {
  id                  String    @id @default(uuid()) @db.Uuid
  title               String    @db.VarChar(80)
  description         String    @default("") @db.VarChar(2000)
  centerLat           Float     @map("center_lat")
  centerLon           Float     @map("center_lon")
  createdById         String    @map("created_by_id") @db.Uuid
  accessInfo          String?   @map("access_info") @db.VarChar(1000)
  photoUrls           String[]  @default([]) @map("photo_urls")
  averageVisibilityMeters Float? @map("average_visibility_meters")
  averageRating       Float?    @map("average_rating")
  reportCount         Int       @default(0) @map("report_count")
  latestReportAt      DateTime? @map("latest_report_at")
  shareUrl            String?   @map("share_url")
  shareableAccessInfo Boolean?  @map("shareable_access_info")
  isDeleted           Boolean   @default(false) @map("is_deleted")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  createdBy        User              @relation(fields: [createdById], references: [id])
  parkingLocations ParkingLocation[]
  diveLogs         DiveLog[]
  spotRatings      SpotRating[]

  @@index([isDeleted, centerLat, centerLon])
  @@map("dive_spots")
}

model ParkingLocation {
  id     String  @id @default(uuid()) @db.Uuid
  lat    Float
  lon    Float
  label  String? @db.VarChar(100)
  spotId String  @map("spot_id") @db.Uuid

  spot DiveSpot @relation(fields: [spotId], references: [id])

  @@map("parking_locations")
}

model DiveLog {
  id              String    @id @default(uuid()) @db.Uuid
  spotId          String    @map("spot_id") @db.Uuid
  authorId        String    @map("author_id") @db.Uuid
  visibilityMeters Float    @map("visibility_meters")
  currentStrength Int       @map("current_strength")
  notes           String?   @db.VarChar(500)
  photoUrls       String[]  @default([]) @map("photo_urls")
  divedAt         DateTime  @map("dived_at")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  spot   DiveSpot @relation(fields: [spotId], references: [id])
  author User     @relation(fields: [authorId], references: [id])

  @@index([spotId, isDeleted, divedAt])
  @@index([authorId, isDeleted, createdAt])
  @@map("dive_logs")
}

model SpotRating {
  id        String   @id @default(uuid()) @db.Uuid
  spotId    String   @map("spot_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  spot DiveSpot @relation(fields: [spotId], references: [id])
  user User     @relation(fields: [userId], references: [id])

  @@unique([userId, spotId])
  @@index([spotId])
  @@map("spot_ratings")
}
