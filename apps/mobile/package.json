{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint app src",
    "lint:fix": "expo lint app src --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "maestro test ${MAESTRO_DEVICE:+--udid $MAESTRO_DEVICE} .maestro/flows/smoke/ && sleep 3 && maestro test ${MAESTRO_DEVICE:+--udid $MAESTRO_DEVICE} --exclude-tags requires-backend .maestro/flows/map/ && sleep 3 && maestro test ${MAESTRO_DEVICE:+--udid $MAESTRO_DEVICE} .maestro/flows/auth/",
    "test:e2e:full": "maestro test ${MAESTRO_DEVICE:+--udid $MAESTRO_DEVICE} .maestro/flows/smoke/ && sleep 3 && maestro test ${MAESTRO_DEVICE:+--udid $MAESTRO_DEVICE} .maestro/flows/map/ && sleep 3 && maestro test ${MAESTRO_DEVICE:+--udid $MAESTRO_DEVICE} .maestro/flows/auth/",
    "test:e2e:smoke": "maestro test .maestro/flows/smoke/",
    "test:e2e:map": "maestro test .maestro/flows/map/",
    "test:e2e:auth": "maestro test .maestro/flows/auth/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.8",
    "expo-location": "^19.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/runtime": "^7.28.6",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29",
    "@types/react": "~19.1.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29",
    "jest-expo": "^54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
